/*
========================================================================================
    Pipeline Manifest
========================================================================================
*/
manifest {
    name = 'DASVA'
    author = 'Denis Nyaga'
    homePage = 'https://github.com/NyagaM/DASVA'
    description = 'A nextflow pipeline for Diploid Assembly and Structural Variation calling with Annotation.'
    mainScript = 'main.nf'
    nextflowVersion = '>=24.10.1'
    version = '2.0'
}

/*
========================================================================================
    Global Environment Variables
========================================================================================
    Redirects temporary files away from system /tmp to avoid storage and permission issues.
*/
env {
    // Redirects tools to use the work directory for temp files instead of system root
    TMPDIR = "\${PWD}/tmp"
}

/*
========================================================================================
    Execution Profiles
========================================================================================
*/
params {
    slurm_account   = ''      // optional
    slurm_partition = ''      // optional
    aws_queue       = ''      // optional
}

profiles {
    // Local execution with Docker (Works for Linux and MacOS)
    docker {
        docker.enabled = true
        // Removed --user flag to allow Docker Desktop (Mac) to handle volume permissions 
        // while remaining functional for Linux users.
        docker.runOptions = "--group-add 100"
        docker.pullTimeout = '20 min'
    }

    // Execution with Singularity (Linux Server/HPC)
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        singularity.pullTimeout = '20 min'
        // Create a local singularity_cache to avoid sudo permission issues in home dirs
        singularity.cacheDir = "${baseDir}/singularity_cache"
        // Bind the local project tmp to the container's internal /tmp
        // This stops system /tmp from filling up during Flye/Hapdup runs
        runOptions = "-B \${PWD}/tmp:/tmp"
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = params.slurm_partition ?: null
        process.clusterOptions = params.slurm_account ? "--account ${params.slurm_account}" : ''
    }
   
    awsbatch {
        process.executor = 'awsbatch'
        process.queue    = params.aws_queue ?: null
    }

    test {
        includeConfig 'conf/test.config'
    }
}

/*
========================================================================================
    Execution Reports
========================================================================================
*/
timeline {
    enabled = true
    file = "${params.output_dir}/execution/timeline.html"
    overwrite = true
}
report {
    enabled = true
    file = "${params.output_dir}/execution/report.html"
    overwrite = true
}
trace {
    enabled = true
    file = "${params.output_dir}/execution/trace.txt"
    overwrite = true
}
dag {
    enabled = true
    file = "${params.output_dir}/execution/dag.html"
    overwrite = true
}

/*
========================================================================================
    Process Configuration
========================================================================================
*/
process {
    errorStrategy = { task.exitStatus in [137,140,143] ? 'retry' : 'finish' }
    maxRetries = 1

    // Resource labels
    withLabel:process_default {
        cpus = 1
        memory = '2.GB'
        time = '1.h'
    }
    withLabel:process_low {
        cpus = 2
        memory = '4.GB'
        time = '2.h'
    }
    withLabel:process_medium {
        cpus = 48
        memory = '24.GB'
        time = '6.h'
    }
    withLabel:process_high {
        cpus = 60
        memory = '200.GB'
        time = '28.h'
    }

    // Container definitions
    withLabel: flye {
        container = 'staphb/flye:2.9.6'
    }
    withLabel: bam2fq {
        container = 'nyagam/dasva:v1.0'
    }
    withLabel: hapdup {
        container = 'mkolmogo/hapdup:0.12'
    }
    withLabel: hapdiff {
        container = 'mkolmogo/hapdiff:0.9'
    }
    withLabel: minimap2 {
        container = 'nyagam/dasva:v1.0'
    }
    withLabel: medaka {
        container = 'ontresearch/medaka:latest'
    }
    withLabel: busco {
        container = 'ezlabgva/busco:v6.0.0_cv1'
    }
    withLabel: annotsv {
        container = 'nyagam/dasva:v1.0'
    }
    withLabel: quast {
        container = 'nyagam/dasva:v1.0'
    }
    withLabel: hifiasm {
        container = 'staphb/hifiasm:latest'
    }
}

// Automatically create the tmp directory if it doesn't exist
def tmp_dir = new File("${baseDir}/tmp")
if( !tmp_dir.exists() ) tmp_dir.mkdirs()
